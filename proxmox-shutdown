#!/bin/bash
# Proxmox Staggered Shutdown Script
# Gracefully shuts down all running LXC containers and VMs with staggered delays
# to reduce load spikes and ensure proper shutdown sequence

# Set PATH for cron environment
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Proxmox command paths
PCT=/usr/sbin/pct
QM=/usr/sbin/qm

# Configuration
LOG_FILE="/var/log/proxmox-midnight-shutdown.log"
STAGGER_DELAY=5          # Seconds between each shutdown command
SHUTDOWN_TIMEOUT=300     # Maximum wait time for graceful shutdown (5 minutes)
FORCE_STOP_TIMEOUT=600   # Maximum total wait including force stop (10 minutes)
FORCE_STOP_WAIT=$((FORCE_STOP_TIMEOUT - SHUTDOWN_TIMEOUT))  # Time to wait after force stop

# Safety checks
command -v "$PCT" >/dev/null 2>&1 || { echo "ERROR: $PCT not found — is this a Proxmox host?"; exit 1; }
command -v "$QM" >/dev/null 2>&1  || { echo "ERROR: $QM not found — is this a Proxmox host?"; exit 1; }

# Ensure log directory exists and is writable
LOG_DIR=$(dirname "$LOG_FILE")
if [ ! -d "$LOG_DIR" ]; then
    mkdir -p "$LOG_DIR" || {
        echo "ERROR: Cannot create log directory $LOG_DIR"
        exit 1
    }
fi

# Test log file writability
touch "$LOG_FILE" 2>/dev/null || {
    echo "ERROR: Cannot write to $LOG_FILE"
    exit 1
}

# Rotate log if it gets too large (>10MB)
if [ -f "$LOG_FILE" ]; then
    LOG_SIZE=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)
    if [ "$LOG_SIZE" -gt 10485760 ]; then
        mv "$LOG_FILE" "${LOG_FILE}.old"
        touch "$LOG_FILE"
    fi
fi

# Logging function
log_message() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

log_message "========================================="
log_message "=== Starting staggered shutdown sequence ==="
log_message "========================================="

# Count initial running containers and VMs
INITIAL_CT=$($PCT list | awk 'NR>1 && $2=="running"' | wc -l)
INITIAL_VM=$($QM list | awk 'NR>1 && $3=="running"' | wc -l)

log_message "Found $INITIAL_CT running LXC containers and $INITIAL_VM running VMs"
log_message "Stagger delay: ${STAGGER_DELAY}s between shutdowns"
log_message "Shutdown timeout: ${SHUTDOWN_TIMEOUT}s"

# Exit if nothing is running
if [ "$INITIAL_CT" -eq 0 ] && [ "$INITIAL_VM" -eq 0 ]; then
    log_message "No running containers or VMs found. Nothing to shut down."
    log_message "=== Shutdown sequence completed ==="
    exit 0
fi

# Phase 1: Shutdown LXC containers one by one with stagger
log_message ""
log_message "PHASE 1: Shutting down LXC containers with ${STAGGER_DELAY}s stagger..."
log_message "---"

CT_COUNT=0
for ctid in $($PCT list | awk 'NR>1 && $2=="running" {print $1}'); do
    CT_COUNT=$((CT_COUNT + 1))
    CT_NAME=$($PCT config "$ctid" | grep "^hostname:" | cut -d' ' -f2 || echo "unknown")
    log_message "[$CT_COUNT/$INITIAL_CT] Stopping LXC $ctid ($CT_NAME)..."

    OUTPUT=$($PCT shutdown "$ctid" --timeout 120 2>&1)
    RET=$?

    echo "$OUTPUT" | tee -a "$LOG_FILE"

    if [ $RET -eq 0 ]; then
        log_message "  ✓ Shutdown command sent to LXC $ctid"
    else
        log_message "  ⚠ LXC $ctid did not stop cleanly (will force later)"
    fi

    if [ "$CT_COUNT" -lt "$INITIAL_CT" ]; then
        sleep "$STAGGER_DELAY"
    fi
done

if [ "$CT_COUNT" -gt 0 ]; then
    log_message "All $CT_COUNT LXC shutdown commands sent"
    sleep "$STAGGER_DELAY"
else
    log_message "No LXC containers to shut down"
fi

# Phase 2: Shutdown VMs one by one with stagger
log_message ""
log_message "PHASE 2: Shutting down VMs with ${STAGGER_DELAY}s stagger..."
log_message "---"

VM_COUNT=0
for vmid in $($QM list | awk 'NR>1 && $3=="running" {print $1}'); do
    VM_COUNT=$((VM_COUNT + 1))
    VM_NAME=$($QM config "$vmid" | grep "^name:" | cut -d' ' -f2 || echo "unknown")
    log_message "[$VM_COUNT/$INITIAL_VM] Stopping VM $vmid ($VM_NAME)..."

    $QM shutdown "$vmid" --timeout 120 2>&1 | tee -a "$LOG_FILE"
    if [ "${PIPESTATUS[0]}" -eq 0 ]; then
        log_message "  ✓ Shutdown command sent to VM $vmid"
    else
        log_message "  ⚠ Warning: Failed to send shutdown to VM $vmid"
    fi

    if [ "$VM_COUNT" -lt "$INITIAL_VM" ]; then
        sleep "$STAGGER_DELAY"
    fi
done

if [ "$VM_COUNT" -gt 0 ]; then
    log_message "All $VM_COUNT VM shutdown commands sent"
else
    log_message "No VMs to shut down"
fi

# Phase 3: Wait for everything to stop gracefully
log_message ""
log_message "PHASE 3: Waiting for graceful shutdown to complete..."
log_message "Timeout: ${SHUTDOWN_TIMEOUT}s"
log_message "---"

ELAPSED=0
CHECK_INTERVAL=10

while [ $ELAPSED -lt $SHUTDOWN_TIMEOUT ]; do
    RUNNING_CT=$($PCT list | awk 'NR>1 && $2=="running"' | wc -l)
    RUNNING_VM=$($QM list | awk 'NR>1 && $3=="running"' | wc -l)

    if [ "$RUNNING_CT" -eq 0 ] && [ "$RUNNING_VM" -eq 0 ]; then
        log_message "✓ SUCCESS: All containers and VMs stopped gracefully after ${ELAPSED}s"
        log_message ""
        log_message "========================================="
        log_message "=== Shutdown sequence completed successfully ==="
        log_message "========================================="
        exit 0
    fi

    log_message "[${ELAPSED}s] Still running: $RUNNING_CT LXCs, $RUNNING_VM VMs"
    sleep $CHECK_INTERVAL
    ELAPSED=$((ELAPSED + CHECK_INTERVAL))
done

# Phase 4: Force stop if graceful shutdown timeout reached
log_message ""
log_message "⚠ WARNING: Graceful shutdown timeout (${SHUTDOWN_TIMEOUT}s) reached"
log_message "PHASE 4: Force stopping remaining containers and VMs..."
log_message "---"

RUNNING_CT=$($PCT list | awk 'NR>1 && $2=="running"' | wc -l)
RUNNING_VM=$($QM list | awk 'NR>1 && $3=="running"' | wc -l)

log_message "Remaining: $RUNNING_CT LXCs, $RUNNING_VM VMs"

# Force stop LXC containers
if [ "$RUNNING_CT" -gt 0 ]; then
    log_message "Force stopping LXC containers..."
    for ctid in $($PCT list | awk 'NR>1 && $2=="running" {print $1}'); do
        CT_NAME=$($PCT config "$ctid" | grep "^hostname:" | cut -d' ' -f2 || echo "unknown")
        log_message "  Force stopping LXC $ctid ($CT_NAME)..."
        $PCT stop "$ctid" 2>&1 | tee -a "$LOG_FILE"
        if [ "${PIPESTATUS[0]}" -ne 0 ]; then
            log_message "  ⚠ Failed to force stop LXC $ctid"
        fi
        sleep 2
    done
fi

# Force stop VMs
if [ "$RUNNING_VM" -gt 0 ]; then
    log_message "Force stopping VMs..."
    for vmid in $($QM list | awk 'NR>1 && $3=="running" {print $1}'); do
        VM_NAME=$($QM config "$vmid" | grep "^name:" | cut -d' ' -f2 || echo "unknown")
        log_message "  Force stopping VM $vmid ($VM_NAME)..."
        $QM stop "$vmid" 2>&1 | tee -a "$LOG_FILE"
        if [ "${PIPESTATUS[0]}" -ne 0 ]; then
            log_message "  ⚠ Failed to force stop VM $vmid"
        fi
        sleep 2
    done
fi

# Final verification after force stop
log_message ""
log_message "Verifying force stop completion..."

FORCE_ELAPSED=0
while [ $FORCE_ELAPSED -lt $FORCE_STOP_WAIT ]; do
    RUNNING_CT=$($PCT list | awk 'NR>1 && $2=="running"' | wc -l)
    RUNNING_VM=$($QM list | awk 'NR>1 && $3=="running"' | wc -l)

    if [ "$RUNNING_CT" -eq 0 ] && [ "$RUNNING_VM" -eq 0 ]; then
        log_message "✓ All containers and VMs stopped after force stop"
        log_message ""
        log_message "========================================="
        log_message "=== Shutdown sequence completed (forced) ==="
        log_message "========================================="
        exit 0
    fi

    sleep $CHECK_INTERVAL
    FORCE_ELAPSED=$((FORCE_ELAPSED + CHECK_INTERVAL))
done

# Ultimate failure
RUNNING_CT=$($PCT list | awk 'NR>1 && $2=="running"' | wc -l)
RUNNING_VM=$($QM list | awk 'NR>1 && $3=="running"' | wc -l)

log_message ""
log_message "✗ CRITICAL ERROR: Some containers/VMs failed to stop"
log_message "Still running after ${FORCE_STOP_TIMEOUT}s total:"
log_message "  LXC containers: $RUNNING_CT"
log_message "  VMs: $RUNNING_VM"

if [ "$RUNNING_CT" -gt 0 ]; then
    log_message "Running LXC containers:"
    $PCT list | awk 'NR>1 && $2=="running" {print "  - " $1}' | tee -a "$LOG_FILE"
fi

if [ "$RUNNING_VM" -gt 0 ]; then
    log_message "Running VMs:"
    $QM list | awk 'NR>1 && $3=="running" {print "  - " $1}' | tee -a "$LOG_FILE"
fi

log_message ""
log_message "========================================="
log_message "=== Shutdown sequence completed with errors ==="
log_message "========================================="

exit 1
